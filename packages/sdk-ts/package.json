{
  "name": "tap-cdc",
  "version": "0.1.3",
  "description": "TypeScript SDK for Tap — PostgreSQL Change Data Capture",
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "index.js",
    "index.d.ts",
    "src/index.ts"
  ],
  "napi": {
    "name": "tap-sdk",
    "targets": [
      "aarch64-apple-darwin",
      "x86_64-apple-darwin",
      "aarch64-unknown-linux-gnu",
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl"
    ]
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "artifacts": "napi artifacts",
    "prepublishOnly": "napi prepublish -t npm",
    "test": "vitest run"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.0",
    "vitest": "^3.0.0"
  },
  "optionalDependencies": {
    "tap-cdc-darwin-arm64": "0.1.1",
    "tap-cdc-darwin-x64": "0.1.1",
    "tap-cdc-linux-arm64-gnu": "0.1.1",
    "tap-cdc-linux-x64-gnu": "0.1.1",
    "tap-cdc-linux-x64-musl": "0.1.1"
  }
}